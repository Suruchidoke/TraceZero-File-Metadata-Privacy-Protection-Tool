<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.hellofx.MainController"
            stylesheets="@styles.css"
            styleClass="root">

    <!-- ── TOP HEADER ──────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header-bar">

            <!-- Logo + App Name -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-shield-alt" iconSize="28" iconColor="#e84545"/>
                <VBox spacing="1">
                    <Label text="OPERATION TRACEZERO" styleClass="header-logo-text"/>
                    <Label text="Metadata Privacy Firewall" styleClass="header-subtitle"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

        </HBox>
    </top>

    <!-- ── LEFT SIDEBAR ────────────────────────────────────── -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar">

            <Region VBox.vgrow="NEVER" minHeight="12"/>

            <ToggleButton fx:id="btnDashboard"
                          text="Dashboard"
                          onAction="#showDashboard"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-th-large" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="btnScanFiles"
                          text="Scan Files"
                          onAction="#showScanFiles"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-file-alt" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="btnClean"
                          text="Clean &amp; Sanitize"
                          onAction="#showClean"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-shield-alt" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="btnReports"
                          text="Reports"
                          onAction="#showReports"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-check-square" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="btnFolderWatch"
                          text="Folder Watch"
                          onAction="#showFolderWatch"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-eye" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <ToggleButton fx:id="btnSettings"
                          text="Settings"
                          onAction="#showSettings"
                          styleClass="sidebar-btn">
                <graphic>
                    <FontIcon iconLiteral="fas-sun" iconSize="15" iconColor="#9ca3b0"/>
                </graphic>
            </ToggleButton>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Version + Status -->
            <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 0 0 4 16;">
                <Circle radius="5" styleClass="status-dot-green"/>
                <Label text="Active" styleClass="sidebar-version" style="-fx-text-fill: #38c96e;"/>
            </HBox>

            <Label text="v1.0.0 · TRACEZERO System" styleClass="sidebar-version"/>

            <Region VBox.vgrow="NEVER" minHeight="12"/>

        </VBox>
    </left>

    <!-- ── MAIN CONTENT AREA ──────────────────────────────── -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>